{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "AUTOPILOT_API_BASE_URL",
    "AUTOPILOT_API_HOST",
    "AUTOPILOT_API_PORT",
    "AUTOPILOT_PYTHON_BIN",
    "BLOB_READ_WRITE_TOKEN",
    "FOUNDEROS_ARTIFACT_OBJECT_BACKEND",
    "FOUNDEROS_ARTIFACT_OBJECT_MIRROR_ROOT",
    "FOUNDEROS_ARTIFACT_SIGNED_URL_BASE",
    "FOUNDEROS_ARTIFACT_SIGNING_SECRET",
    "FOUNDEROS_ARTIFACT_STORAGE_URI_PREFIX",
    "FOUNDEROS_ARTIFACT_STORE_MODE",
    "FOUNDEROS_CONTROL_PLANE_DATABASE_URL",
    "FOUNDEROS_CONTROL_PLANE_STATE_DIR",
    "FOUNDEROS_DELIVERY_PYTHON_BIN",
    "FOUNDEROS_DEPLOYMENT_ENV",
    "FOUNDEROS_ENABLE_SYNTHETIC_STATE_SEEDS",
    "FOUNDEROS_EXECUTION_HANDOFF_DATABASE_URL",
    "FOUNDEROS_EXECUTION_HANDOFF_STORE_PATH",
    "FOUNDEROS_EXECUTION_KERNEL_BASE_URL",
    "FOUNDEROS_INTEGRATION_ROOT",
    "FOUNDEROS_LOCAL_ARTIFACT_STORE_ROOT",
    "FOUNDEROS_MIGRATION_TEST_DATABASE_URL",
    "FOUNDEROS_ORCHESTRATION_ARTIFACTS_ROOT",
    "FOUNDEROS_ORCHESTRATION_DELIVERIES_ROOT",
    "FOUNDEROS_ORCHESTRATION_VALIDATION_COMMANDS_JSON",
    "FOUNDEROS_VERCEL_BLOB_READ_WRITE_TOKEN",
    "HERMES_MEMORY_SIDECAR_BASE_URL",
    "FOUNDEROS_PARITY_ALLOW_BLOCKED",
    "FOUNDEROS_PARITY_BASE_URL",
    "FOUNDEROS_PARITY_CHAIN_COUNT",
    "FOUNDEROS_PARITY_DISCOVERY_IDEA_ID",
    "FOUNDEROS_PARITY_DISCOVERY_SESSION_ID",
    "FOUNDEROS_PARITY_INTAKE_SESSION_ID",
    "FOUNDEROS_PARITY_MIN_COMPLETE_CHAIN_COUNT",
    "FOUNDEROS_PARITY_MIN_SCENARIO_VARIANT_COUNT",
    "FOUNDEROS_PARITY_PROJECT_ID",
    "FOUNDEROS_PARITY_REQUIRE_DIVERSE_SCENARIOS",
    "FOUNDEROS_PARITY_REQUIRE_COMPLETE_CHAIN",
    "FOUNDEROS_PARITY_REQUIRE_OPERATOR_DATA",
    "FOUNDEROS_REVIEW_ACTION_TARGETS_JSON",
    "FOUNDEROS_REVIEW_PRESET",
    "FOUNDEROS_REVIEW_SUITE_MODE",
    "FOUNDEROS_REVIEW_SUITE_TARGETS_JSON",
    "FOUNDEROS_STACK_FORCE_BUILD",
    "FOUNDEROS_STACK_READY_TIMEOUT_MS",
    "FOUNDEROS_WEB_HOST",
    "FOUNDEROS_WEB_PORT",
    "GATEWAY_HOST",
    "GATEWAY_PORT",
    "NODE_ENV",
    "MULTICA_KERNEL_BASE_URL",
    "QUORUM_API_BASE_URL",
    "QUORUM_PYTHON_BIN",
    "VITEST"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

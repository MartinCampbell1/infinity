{
  "name": "@founderos/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c 'next dev --hostname ${FOUNDEROS_WEB_HOST:-127.0.0.1} --port ${FOUNDEROS_WEB_PORT:-3737}'",
    "build": "next build",
    "start": "sh -c 'next start --hostname ${FOUNDEROS_WEB_HOST:-127.0.0.1} --port ${FOUNDEROS_WEB_PORT:-3737}'",
    "lint": "eslint app components lib scripts next.config.mjs postcss.config.mjs eslint.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "sh -c 'if [ ! -f .next/BUILD_ID ]; then npm run build; fi && npm run test:integration-gate && node ./scripts/smoke-shell-contract.mjs'",
    "test:integration-gate": "npx vitest run app/api/control/execution/integration-gate.test.ts",
    "test:live-parity": "node ./scripts/check-live-parity.mjs",
    "test:live-review-actions": "node ./scripts/check-live-review-actions.mjs",
    "test:live-review-batch-routes": "node ./scripts/check-live-review-batch-routes.mjs",
    "test:live-review-memory": "node ./scripts/check-live-review-memory.mjs",
    "test:live-review-pressure-actions": "node ./scripts/check-live-review-pressure-actions.mjs",
    "test:live-review-pressure-entry-links": "node ./scripts/check-live-review-pressure-entry-links.mjs",
    "test:live-settings-parity-links": "node ./scripts/check-live-settings-parity-links.mjs",
    "test:live-review-playbook": "node ./scripts/check-live-review-playbook.mjs",
    "test:live-review-preset-suite": "node ./scripts/check-live-review-preset-suite.mjs"
  },
  "dependencies": {
    "@founderos/api-clients": "*",
    "@founderos/config": "*",
    "@founderos/ui": "*",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@founderos/eslint-config": "*",
    "@founderos/typescript-config": "*",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.19.0",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}

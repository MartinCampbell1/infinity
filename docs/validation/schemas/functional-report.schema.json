{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Infinity Functional Report",
  "type": "object",
  "required": ["run_id", "generated_at", "status", "checks", "scenarios"],
  "properties": {
    "run_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "status": { "type": "string", "enum": ["passed", "failed"] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed"] },
          "detail": { "type": ["string", "null"] }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed"] },
          "detail": { "type": ["string", "null"] }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

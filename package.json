{
  "name": "infinity",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/shell/apps/web",
    "apps/work-ui",
    "packages/*"
  ],
  "scripts": {
    "setup": "npm ci",
    "setup:refresh-lockfile": "npm install --package-lock-only",
    "localhost:start": "node ./scripts/start-localhost.mjs",
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "shell:start": "npm run start --workspace @founderos/web",
    "shell:dev": "npm run dev --workspace @founderos/web",
    "shell:build": "npm run build --workspace @founderos/web",
    "shell:typecheck": "npm run typecheck --workspace @founderos/web",
    "shell:test": "npm run test --workspace @founderos/web",
    "shell:test:delivery-manifests": "npm run test:delivery-manifests --workspace @founderos/web",
    "shell:control-plane:migrations:dry-run": "npm run control-plane:migrations:dry-run --workspace @founderos/web",
    "shell:control-plane:migrations:apply": "npm run control-plane:migrations:apply --workspace @founderos/web",
    "shell:control-plane:migrations:status": "npm run control-plane:migrations:status --workspace @founderos/web",
    "shell:control-plane:migrations:smoke": "npm run control-plane:migrations:smoke --workspace @founderos/web",
    "shell:control-plane:migrations:drift": "npm run control-plane:migrations:drift --workspace @founderos/web",
    "shell:control-plane:migrations:drift:test": "npm run control-plane:migrations:drift:test --workspace @founderos/web",
    "shell:control-plane:preflight": "npm run control-plane:preflight --workspace @founderos/web",
    "validate:full": "python3 scripts/validation/run_infinity_validation.py --require-runnable-result",
    "browser:e2e:solo": "python3 scripts/validation/run_browser_e2e_solo.py",
    "validate:quick": "python3 scripts/validation/run_infinity_validation.py --skip-static-checks",
    "work-ui:dev": "WORK_UI_HOST=127.0.0.1 WORK_UI_PORT=3101 npm run dev --workspace open-webui",
    "work-ui:build": "npm run build --workspace open-webui",
    "work-ui:check": "npm run check --workspace open-webui",
    "work-ui:preview": "npm run preview --workspace open-webui",
    "work-ui:test": "npm run test:frontend:ci --workspace open-webui",
    "release:packet": "node ./scripts/release/generate-release-packet.mjs",
    "docs:architecture:test": "node --test ./scripts/docs/architecture-diagrams.test.mjs",
    "docs:dev-setup:test": "node --test ./scripts/docs/dev-setup-doc.test.mjs",
    "docs:agent-task-templates:test": "node --test ./scripts/docs/agent-task-templates-doc.test.mjs",
    "docs:operator-quickstart:test": "node --test ./scripts/docs/operator-quickstart-doc.test.mjs",
    "docs:operator-glossary:test": "node --test ./scripts/docs/operator-glossary-doc.test.mjs",
    "docs:known-limitations:test": "node --test ./scripts/docs/known-limitations-doc.test.mjs",
    "docs:security-model:test": "node --test ./scripts/docs/security-model-doc.test.mjs",
    "docs:production-readiness:test": "node --test ./scripts/docs/production-readiness-doc.test.mjs",
    "docs:staging-topology:test": "node --test ./scripts/docs/staging-topology-doc.test.mjs",
    "security:embedded-auth": "node ./scripts/security/check-work-ui-embedded-auth.mjs",
    "security:sbom": "node ./scripts/security/generate-sbom.mjs",
    "security:audit:critical": "node ./scripts/security/critical-vulnerability-gate.mjs",
    "security:supply-chain": "npm run security:sbom && npm run security:audit:critical",
    "qa:shared-design-tokens": "node ./scripts/qa/shared-design-tokens-gate.mjs",
    "qa:manual-screenshot-checklist:test": "node --test ./scripts/qa/manual-screenshot-checklist-gate.test.mjs",
    "qa:critical-coverage": "node ./scripts/qa/critical-coverage-gate.mjs",
    "qa:critical-coverage:test": "node --test ./scripts/qa/critical-coverage-gate.test.mjs"
  },
  "overrides": {
    "protobufjs": "7.5.5"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  }
}
